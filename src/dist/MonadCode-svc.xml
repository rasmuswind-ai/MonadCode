<service>
  <id>MonadCode</id>
  <name>Monad Code</name>
  <description>Lightweight PowerShell script scheduler with web UI</description>
  <executable>D:\CLAUDE_CODE\PSScheduler\dist\monadcode.exe</executable>
  <argument>run</argument>
  <workingdirectory>D:\CLAUDE_CODE\PSScheduler\dist</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>3</keepFiles>
  </log>
  <onfailure action="restart" delay="5 sec" />
</service>
